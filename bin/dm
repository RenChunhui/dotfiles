#!/bin/sh

# 自定义 cli 名称
export BIN_NAME='dm'

# dotfiles 路径
export BIN_PATH=$HOME/.config/dotfiles

# GitHub 代理
export GITHUB_PROXY='https://ghproxy.com'

export BOLD=$'\e[1m'
export DIM=$'\e[2m'
export UNDERLINED=$'\e[4m'

export BLACK=$'\e[30m'
export RED=$'\e[31m'
export GREEN=$'\e[32m'
export YELLOW=$'\e[33m'
export BLUE=$'\e[34'
export MAGENTA=$'\e[95m'
export CYAN=$'\e[36m'
export WHITE=$'\e[97m'

export RESET=$'\e[0m'
export RESET_BOLD=$'\e[21m'
export RESET_DIM=$'\e[22m'

export ICON_ASK='?'
export ICON_INFO='➜'
export ICON_OK='✔'
export ICON_WARN='⚠'
export ICON_FAIL='✖'
export ICON_ARROR_RIGHT="❯"
export ICON_STEP='⧗'



#######################################
# 帮助
#######################################
usage() {
cat <<EOF
Usage: ${BIN_NAME} [command]

Commands:
  add         添加环境
  remove      移除环境
  clean       清理环境
  checkhealth 检测环境
  version     查看版本
  help        帮助文档
EOF
}

#######################################
# 入口
#######################################
main() {
  case $1 in
    add)
      sh $BIN_PATH/Commands/add "$2"
      ;;
    remove)
      sh $BIN_PATH/Commands/remove "$2"
      ;;
    clean)
      ;;
    checkhealth)
      ;;
    '' | h | help)
      usage
      ;;
    *)
      ;;
  esac
}

main "$@"
