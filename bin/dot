#!/bin/sh

usage() {
cat <<EOF
+------------------------------------------+
|          __      __  _____ __            |
|     ____/ /___  / /_/ __(_) /__  _____   |
|    / __  / __ \/ __/ /_/ / / _ \/ ___/   |
|   / /_/ / /_/ / /_/ __/ / /  __(__  )    |
|   \__,_/\____/\__/_/ /_/_/\___/____/     |
|                                          |
+------------------------------------------+

USAGE
  dot [command]

Available Commands:
  install     安装
  uninstall   卸载
  help        帮助
EOF
}

usage_darwin() {
cat <<EOF
Usage: dot install [command]
Available Commands:
  brew      Homebrew 安装
  git       Git 环境
  alacritty 终端配置
  os        系统偏好设置
  neovim    NeoVim 配置
  node      Node 环境
  zsh       zsh 环境
  help      帮助文档
EOF
}

install_darwin() {
  case $2 in
    '')
      dot install zsh
      dot install brew
      dot install alacritty
      dot install git
      dot install neovim
      dot install os
      ;;
    zsh)
      zsh "$(pwd)/user/zsh/install_darwin.sh"
      ;;
    brew)
      sh "$(pwd)/user/homebrew/install.sh"
      ;;
    alacritty)
      sh "$(pwd)/user/alacritty/install.sh"
      ;;
    git)
      sh "$(pwd)/user/git/install.sh"
      ;;
    neovim)
      sh "$(pwd)/user/neovim/install.sh"
      ;;
    os)
      sh "$(pwd)/user/os/install_darwin.sh"
      ;;
    help)
      usage_darwin
      ;;
  esac
}

install_linux() {
  echo "linux"
}

uninstall() {
  echo "uninstall"
}

main() {
  case $1 in
    install)
      if [[ "$(uname)" == "Darwin" ]]; then
        install_darwin $@
      else
        install_linux $@
      fi
      ;;
    uninstall)
      uninstall
      ;;
    help)
      usage
      ;;
    esac
}

main "$@"
